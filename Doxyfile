# Doxygen Configuration File for kribu
# See https://www.doxygen.nl/manual/config.html for details

# Project info
PROJECT_NAME           = "kribu"
PROJECT_BRIEF          = "Sholo Guti AI Engine in C++20 and Python"
OUTPUT_DIRECTORY       = build/doc
CREATE_SUBDIRS         = NO
ALLOW_UNICODE_NAMES    = YES

# Input configuration
INPUT                  = engine/include bindings/src doc README.md
FILE_PATTERNS          = *.hpp *.cpp *.h *.c *.md
RECURSIVE              = YES
EXCLUDE_PATTERNS       = */build/* */.venv/* */tests/*
USE_MDFILE_AS_MAINPAGE = README.md

# Extraction and parsing
EXTRACT_ALL            = YES
EXTRACT_PRIVATE        = YES
EXTRACT_STATIC         = YES
HIDE_UNDOC_MEMBERS     = NO
HIDE_UNDOC_CLASSES     = NO
JAVADOC_AUTOBRIEF      = YES
QT_AUTOBRIEF           = YES
MULTILINE_CPP_IS_BRIEF = YES
BUILTIN_STL_SUPPORT    = YES

# Warning settings
QUIET                  = NO
WARNINGS               = YES
WARN_IF_UNDOCUMENTED   = NO
WARN_IF_DOC_ERROR      = YES
WARN_NO_PARAMDOC       = NO

# HTML generation and styling (using Doxygen Awesome CSS)
GENERATE_HTML          = YES
HTML_OUTPUT            = html
HTML_FILE_EXTENSION    = .html
HTML_COLORSTYLE        = LIGHT
HTML_EXTRA_STYLESHEET  = doc/doxygen-awesome.css
GENERATE_TREEVIEW      = YES
DISABLE_INDEX          = NO
FULL_SIDEBAR           = YES
HTML_DYNAMIC_MENUS     = YES
HTML_DYNAMIC_SECTIONS  = YES

# LaTeX and other formats disabled for speed
GENERATE_LATEX         = NO
GENERATE_RTF           = NO
GENERATE_XML           = NO

# Graphviz Diagrams (crisp interactive SVG graphics)
HAVE_DOT               = YES
DOT_NUM_THREADS        = 4
DOT_IMAGE_FORMAT       = svg
INTERACTIVE_SVG        = YES
CLASS_DIAGRAMS         = YES
CLASS_GRAPH            = YES
COLLABORATION_GRAPH    = YES
GROUP_GRAPHS           = YES
TEMPLATE_RELATIONS     = YES
INCLUDE_GRAPH          = YES
INCLUDED_BY_GRAPH      = YES
CALL_GRAPH             = YES
CALLER_GRAPH           = YES
GRAPHICAL_HIERARCHY    = YES
DIRECTORY_GRAPH        = YES
